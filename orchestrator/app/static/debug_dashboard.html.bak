<!DOCTYPE html>
<html lang=\"en\">
<head>
  <meta charset=\"UTF-8\" />
  <title>HRI Perception Live Debug</title>
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />
  <style>
    :root {
      color-scheme: dark;
      --bg: #0f1115;
      --panel: #171a21;
      --panel-2: #1f2430;
      --text: #e7eaf0;
      --muted: #a7b0c0;
      --ok: #39d98a;
      --warn: #ffcc66;
      --bad: #ff6b6b;
      --border: #2b3240;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }
    .wrap {
      max-width: 1500px;
      margin: 0 auto;
      padding: 16px;
    }
    h1 {
      margin: 0 0 14px 0;
      font-size: 24px;
    }
    .sub {
      color: var(--muted);
      margin-bottom: 14px;
      font-size: 14px;
    }
    .status-strip {
      display: grid;
      grid-template-columns: repeat(4, minmax(180px, 1fr));
      gap: 10px;
      margin-bottom: 16px;
    }
    .card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px;
    }
    .metric-label {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
    }
    .metric-value {
      font-size: 20px;
      font-weight: 700;
      word-break: break-word;
    }
    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      align-items: start;
    }
    .image-card h2,
    .info-card h2 {
      margin: 0 0 10px 0;
      font-size: 18px;
    }
    .image-box {
      width: 100%;
      background: #0b0d12;
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      min-height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    img {
      width: 100%;
      height: auto;
      display: block;
    }
    .details {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }
    .kv {
      background: var(--panel-2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px;
      min-height: 60px;
    }
    .kv .k {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
    }
    .kv .v {
      font-size: 15px;
      font-weight: 600;
      word-break: break-word;
    }
    .ok { color: var(--ok); }
    .bad { color: var(--bad); }
    .footer {
      margin-top: 14px;
      color: var(--muted);
      font-size: 12px;
    }
    @media (max-width: 980px) {
      .status-strip, .grid, .details {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class=\"wrap\">
    <h1>HRI Perception Live Debug</h1>
    <div class=\"sub\">Operational preview for live video, emotion state, and gateway health.</div>

    <div class=\"status-strip\">
      <div class=\"card\">
        <div class=\"metric-label\">Gateway status</div>
        <div class=\"metric-value\" id=\"gatewayConnected\">Loading...</div>
      </div>
      <div class=\"card\">
        <div class=\"metric-label\">Emotion</div>
        <div class=\"metric-value\" id=\"emotionLabel\">Loading...</div>
      </div>
      <div class=\"card\">
        <div class=\"metric-label\">Server pipeline latency</div>
        <div class=\"metric-value\" id=\"serverLatency\">Loading...</div>
      </div>
      <div class=\"card\">
        <div class=\"metric-label\">Forwarded frames</div>
        <div class=\"metric-value\" id=\"forwardedFrames\">Loading...</div>
      </div>
    </div>

    <div class=\"grid\">
      <div class=\"card image-card\">
        <h2>Latest Input Frame</h2>
        <div class=\"image-box\">
          <img id=\"inputFrame\" alt=\"Latest input frame\" />
        </div>
      </div>

      <div class=\"card image-card\">
        <h2>Latest Annotated Frame</h2>
        <div class=\"image-box\">
          <img id=\"annotatedFrame\" alt=\"Latest annotated frame\" />
        </div>
      </div>
    </div>

    <div class=\"card info-card\" style=\"margin-top: 16px;\">
      <h2>Live Details</h2>
      <div class=\"details\">
        <div class=\"kv\"><div class=\"k\">Face detected</div><div class=\"v\" id=\"faceDetected\">-</div></div>
        <div class=\"kv\"><div class=\"k\">Confidence</div><div class=\"v\" id=\"emotionConfidence\">-</div></div>
        <div class=\"kv\"><div class=\"k\">Frame ID</div><div class=\"v\" id=\"frameId\">-</div></div>
        <div class=\"kv\"><div class=\"k\">Active model</div><div class=\"v\" id=\"activeModel\">-</div></div>
        <div class=\"kv\"><div class=\"k\">Backend inference latency</div><div class=\"v\" id=\"backendLatency\">-</div></div>
        <div class=\"kv\"><div class=\"k\">Worker queue delay</div><div class=\"v\" id=\"workerQueueDelay\">-</div></div>
        <div class=\"kv\"><div class=\"k\">Last sample timestamp</div><div class=\"v\" id=\"lastSampleTs\">-</div></div>
        <div class=\"kv\"><div class=\"k\">Last emotion timestamp</div><div class=\"v\" id=\"emotionTs\">-</div></div>
      </div>
      <div class=\"footer\">Refresh interval: 500 ms. This page is for operational visibility, not formal benchmark judgment.</div>
    </div>
  </div>

  <script>
    const inputFrame = document.getElementById("inputFrame");
    const annotatedFrame = document.getElementById("annotatedFrame");

    function text(id, value) {
      document.getElementById(id).textContent = value ?? "-";
    }

    function fmtMs(value) {
      if (value === null || value === undefined) return "-";
      return `${Number(value).toFixed(2)} ms`;
    }

    function fmtConfidence(value) {
      if (value === null || value === undefined) return "-";
      return `${(Number(value) * 100).toFixed(1)}%`;
    }

    function setGatewayStatus(connected) {
      const el = document.getElementById("gatewayConnected");
      el.textContent = connected ? "Connected" : "Disconnected";
      el.className = `metric-value ${connected ? "ok" : "bad"}`;
    }

    async function fetchJson(url) {
      const r = await fetch(url, { cache: "no-store" });
      if (!r.ok) throw new Error(`${url} -> ${r.status}`);
      return r.json();
    }

    async function refreshData() {
      const cacheBust = Date.now();
      inputFrame.src = `/debug/image/input?t=${cacheBust}`;
      annotatedFrame.src = `/debug/image/annotated?t=${cacheBust}`;

      try {
        const [gateway, emotionStateWrap, emotionMetricsWrap] = await Promise.all([
          fetchJson("http://localhost:8010/status"),
          fetchJson("/state/emotion"),
          fetchJson("/metrics/live/emotion"),
        ]);

        const emotionState = emotionStateWrap.emotion_state || null;
        const emotionMetrics = emotionMetricsWrap.metrics || null;

        setGatewayStatus(Boolean(gateway.session && gateway.session.connected));
        text("forwardedFrames", gateway.video?.forwarded_frame_count ?? gateway.video?.received_sample_count ?? "-");
        text("lastSampleTs", gateway.video?.last_sample_timestamp_utc ?? "-");

        if (emotionState) {
          const prediction = emotionState.prediction || null;
          text("emotionLabel", prediction?.dominant_label ?? "No prediction");
          text("emotionConfidence", fmtConfidence(prediction?.confidence));
          text("frameId", emotionState.frame_id ?? "-");
          text("activeModel", emotionState.active_model ?? "-");
          text("faceDetected", emotionState.face_detected ? "Yes" : "No");
          text("emotionTs", prediction?.timestamp_utc ?? emotionState.server_ingest_timestamp ?? "-");
        } else {
          text("emotionLabel", "No state");
          text("emotionConfidence", "-");
          text("frameId", "-");
          text("activeModel", "-");
          text("faceDetected", "-");
          text("emotionTs", "-");
        }

        text("serverLatency", fmtMs(emotionMetrics?.server_pipeline_latency_ms));
        text("backendLatency", fmtMs(emotionMetrics?.backend_inference_latency_ms));
        text("workerQueueDelay", fmtMs(emotionMetrics?.worker_queue_delay_ms));
      } catch (err) {
        setGatewayStatus(false);
        text("emotionLabel", "Fetch error");
        console.error(err);
      }
    }

    refreshData();
    setInterval(refreshData, 500);
  </script>
</body>
</html>
